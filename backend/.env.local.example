# ------------------------------
# Shared Mode
# ------------------------------
APP_ENV=local

# ------------------------------
# Frontend (Vite local dev)
# ------------------------------
VITE_API_BASE_URL=/api

# ------------------------------
# Backend (Local Node server)
# ------------------------------
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
BACKEND_APP_PIN=1234
APP_AUTH_SECRET=change-this-to-a-long-random-secret
APP_TOKEN_TTL_MS=86400000
SUPABASE_TLS_INSECURE=false
